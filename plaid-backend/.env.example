PLAID_CLIENT_ID=replace-with-your-plaid-client-id
PLAID_SECRET=replace-with-your-plaid-secret
PLAID_ENV=sandbox
PLAID_TRANSACTIONS_ENABLED=true
PLAID_TRANSACTIONS_LOOKBACK_DAYS=30
PLAID_LIABILITIES_ENABLED=false
PLAID_LIABILITIES_LINK_ENABLED=false
# Explicit true/false overrides the default. When blank, rate limiting is enabled
# on Render, for NODE_ENV=production, or with PLAID_ENV=production; local development is disabled.
# All limits use RATE_LIMIT_GENERAL_WINDOW_MS (15 minutes by default).
RATE_LIMIT_ENABLED=
RATE_LIMIT_GENERAL_WINDOW_MS=900000
RATE_LIMIT_GENERAL_MAX=300
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_LINK_TOKEN_MAX=10
RATE_LIMIT_TOKEN_EXCHANGE_MAX=10
RATE_LIMIT_ACCOUNTS_MAX=20
RATE_LIMIT_TRANSACTIONS_MAX=10
RATE_LIMIT_LIABILITIES_MAX=10
# Render sits behind one reverse proxy. Keep this at 1 when deployed and 0 locally.
RATE_LIMIT_TRUST_PROXY_HOPS=1
PORT=3001
APP_API_KEY=local-dev-app-api-key-change-me
PLAID_PERSONAL_USER_KEY=personal
PLAID_TOKEN_STORE_PATH=.plaid-token-store.json
PLAID_REDIRECT_URI=https://plaid-backend-2wqb.onrender.com/plaid/oauth
TOKEN_STORE_DRIVER=json
DATABASE_URL=
TOKEN_ENCRYPTION_KEY=
MIGRATE_JSON_TOKEN_STORE_ON_START=false

AUTH_MODE=personal
APPLE_CLIENT_ID=
SESSION_TTL_DAYS=30

# Local DEBUG-only auth fallback. Never enable this on production/Render.
# Keep PLAID_ENV=sandbox for local development auth.
# Real local Sign in with Apple still requires DATABASE_URL and APPLE_CLIENT_ID.
DEV_AUTH_ENABLED=true
DEV_AUTH_USER_ID=dev_local_user
DEV_AUTH_EMAIL=debug@local.caldera
DEV_AUTH_FULL_NAME=Local Debug User
