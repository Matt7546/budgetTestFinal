PLAID_CLIENT_ID=replace-with-your-plaid-client-id
PLAID_SECRET=replace-with-your-plaid-secret
PLAID_ENV=sandbox
PLAID_TRANSACTIONS_ENABLED=true
PLAID_LIABILITIES_ENABLED=false
PORT=3001
APP_API_KEY=local-dev-app-api-key-change-me
PLAID_PERSONAL_USER_KEY=personal
PLAID_TOKEN_STORE_PATH=.plaid-token-store.json
PLAID_REDIRECT_URI=https://plaid-backend-2wqb.onrender.com/plaid/oauth
TOKEN_STORE_DRIVER=json
DATABASE_URL=
TOKEN_ENCRYPTION_KEY=
MIGRATE_JSON_TOKEN_STORE_ON_START=false

AUTH_MODE=personal
APPLE_CLIENT_ID=
SESSION_TTL_DAYS=30

# Local DEBUG-only auth fallback. Never enable this on production/Render.
# Keep PLAID_ENV=sandbox for local development auth.
# Real local Sign in with Apple still requires DATABASE_URL and APPLE_CLIENT_ID.
DEV_AUTH_ENABLED=true
DEV_AUTH_USER_ID=dev_local_user
DEV_AUTH_EMAIL=debug@local.caldera
DEV_AUTH_FULL_NAME=Local Debug User
